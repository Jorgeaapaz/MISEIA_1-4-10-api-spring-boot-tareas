  "item": [
    {
      "name": "Tareas",
      "item": [
        {
          "name": "Listar todas las tareas",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json", "type": "text" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/tareas",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tareas"]
            },
            "description": "Retorna la lista completa de tareas almacenadas."
          },
          "response": [
            {
              "name": "200 OK - Lista de tareas",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "[\n  {\n    \"id\": 1,\n    \"titulo\": \"Aprender Spring Boot\",\n    \"descripcion\": \"Completar el módulo de APIs REST\",\n    \"completada\": false,\n    \"fechaCreacion\": \"2026-05-26T10:00:00\",\n    \"fechaActualizacion\": \"2026-05-26T10:00:00\"\n  }\n]"
            }
          ]
        },
        {
          "name": "Obtener tarea por ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json", "type": "text" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/tareas/{{id}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tareas", "{{id}}"],
              "variable": [
                {
                  "key": "id",
                  "value": "1",
                  "description": "ID de la tarea"
                }
              ]
            },
            "description": "Retorna una tarea específica por su ID. Devuelve 404 si no existe."
          },
          "response": [
            {
              "name": "200 OK - Tarea encontrada",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"id\": 1,\n  \"titulo\": \"Aprender Spring Boot\",\n  \"descripcion\": \"Completar el módulo de APIs REST\",\n  \"completada\": false,\n  \"fechaCreacion\": \"2026-05-26T10:00:00\",\n  \"fechaActualizacion\": \"2026-05-26T10:00:00\"\n}"
            },
            {
              "name": "404 Not Found",
              "status": "Not Found",
              "code": 404,
              "header": [],
              "body": ""
            }
          ]
        },
        {
          "name": "Listar tareas por estado",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json", "type": "text" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/tareas/estado/{{completada}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tareas", "estado", "{{completada}}"],
              "variable": [
                {
                  "key": "completada",
                  "value": "false",
                  "description": "Estado de la tarea: true (completada) o false (pendiente)"
                }
              ]
            },
            "description": "Filtra tareas por su estado de completitud. Usar true para completadas, false para pendientes."
          },
          "response": [
            {
              "name": "200 OK - Tareas pendientes",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "[\n  {\n    \"id\": 1,\n    \"titulo\": \"Aprender Spring Boot\",\n    \"descripcion\": \"Completar el módulo de APIs REST\",\n    \"completada\": false,\n    \"fechaCreacion\": \"2026-05-26T10:00:00\",\n    \"fechaActualizacion\": \"2026-05-26T10:00:00\"\n  }\n]"
            }
          ]
        },
        {
          "name": "Crear tarea",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json", "type": "text" },
              { "key": "Accept", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"Nueva tarea de ejemplo\",\n  \"descripcion\": \"Descripción detallada de la tarea\",\n  \"completada\": false\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/tareas",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tareas"]
            },
            "description": "Crea una nueva tarea. El campo 'titulo' es obligatorio (máx. 200 chars). La 'descripcion' es opcional (máx. 1000 chars)."
          },
          "response": [
            {
              "name": "201 Created - Tarea creada",
              "status": "Created",
              "code": 201,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"id\": 2,\n  \"titulo\": \"Nueva tarea de ejemplo\",\n  \"descripcion\": \"Descripción detallada de la tarea\",\n  \"completada\": false,\n  \"fechaCreacion\": \"2026-05-26T12:00:00\",\n  \"fechaActualizacion\": \"2026-05-26T12:00:00\"\n}"
            },
            {
              "name": "400 Bad Request - Validación fallida",
              "status": "Bad Request",
              "code": 400,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"status\": 400,\n  \"error\": \"Bad Request\",\n  \"message\": \"El título es obligatorio\"\n}"
            }
          ]
        },
        {
          "name": "Actualizar tarea",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json", "type": "text" },
              { "key": "Accept", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"Tarea actualizada\",\n  \"descripcion\": \"Descripción modificada\",\n  \"completada\": true\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/tareas/{{id}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tareas", "{{id}}"],
              "variable": [
                {
                  "key": "id",
                  "value": "1",
                  "description": "ID de la tarea a actualizar"
                }
              ]
            },
            "description": "Actualiza completamente una tarea existente por su ID. Devuelve 404 si no existe."
          },
          "response": [
            {
              "name": "200 OK - Tarea actualizada",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"id\": 1,\n  \"titulo\": \"Tarea actualizada\",\n  \"descripcion\": \"Descripción modificada\",\n  \"completada\": true,\n  \"fechaCreacion\": \"2026-05-26T10:00:00\",\n  \"fechaActualizacion\": \"2026-05-26T13:00:00\"\n}"
            },
            {
              "name": "404 Not Found",
              "status": "Not Found",
              "code": 404,
              "header": [],
              "body": ""
            }
          ]
        },
        {
          "name": "Eliminar tarea",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/tareas/{{id}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tareas", "{{id}}"],
              "variable": [
                {
                  "key": "id",
                  "value": "1",
                  "description": "ID de la tarea a eliminar"
                }
              ]
            },
            "description": "Elimina una tarea por su ID. Devuelve 204 si se eliminó correctamente, 404 si no existe."
          },
          "response": [
            {
              "name": "204 No Content - Eliminada correctamente",
              "status": "No Content",
              "code": 204,
              "header": [],
              "body": ""
            },
            {
              "name": "404 Not Found",
              "status": "Not Found",
              "code": 404,
              "header": [],
              "body": ""
            }
          ]
        }
      ]
