# ============================================================
# .env.example — copy to .env and fill in real values
# Spring Boot reads these as property overrides automatically:
#   SPRING_DATASOURCE_URL  →  spring.datasource.url
#   SPRING_DATASOURCE_USERNAME  →  spring.datasource.username
#   etc.
# ============================================================

# Active profile: 'default' = H2 in-memory (dev/test), 'prod' = MySQL
SPRING_PROFILES_ACTIVE=default

# MySQL datasource (only needed when SPRING_PROFILES_ACTIVE=prod)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=tareasdb
SPRING_DATASOURCE_URL=jdbc:mysql://${DB_HOST}:${DB_PORT}/${DB_NAME}?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
SPRING_DATASOURCE_DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver
SPRING_DATASOURCE_USERNAME=your_db_username_here
SPRING_DATASOURCE_PASSWORD=your_db_password_here
SPRING_JPA_DATABASE_PLATFORM=org.hibernate.dialect.MySQLDialect

# Server
SERVER_PORT=8080
